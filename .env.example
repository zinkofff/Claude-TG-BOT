# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# Claude model (claude-haiku-4-5 for cost efficiency, claude-sonnet-4-6 for quality)
CLAUDE_MODEL=claude-haiku-4-5

# How many articles to include in each daily digest
DIGEST_ARTICLE_COUNT=5

# DynamoDB table names
ARTICLES_TABLE=claude-tg-bot-articles
DRAFTS_TABLE=claude-tg-bot-drafts

# AWS (for local development)
AWS_DEFAULT_REGION=us-east-1
# AWS_ENDPOINT_URL=http://localhost:8000  # Uncomment for DynamoDB Local

# Logging
LOG_LEVEL=INFO
